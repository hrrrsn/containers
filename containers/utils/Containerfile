FROM registry.access.redhat.com/ubi10/ubi-minimal:10.2-1782798957@sha256:b217fa65d8c21058887b18f005f587e47a17dd1281a5196ac88d01724a273dbd

LABEL org.opencontainers.image.source=https://github.com/hrrrsn/containers
LABEL org.opencontainers.image.description="UBI 10 minimal image with jq, rsync, and curl"

RUN microdnf install -y --setopt=install_weak_deps=0 jq rsync curl && \
    microdnf clean all
